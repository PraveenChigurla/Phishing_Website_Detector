{
  "manifest_version": 3,
  "name": "Phishing Scanner Extension",
  "version": "1.0",
  "description": "Scan URLs for phishing using multiple APIs",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
    "16": "clickbait.png",
    "48": "clickbait.png",
    "128": "clickbait.png"
    }
  },
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "webNavigation",
    "notifications",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*",
    "http://127.0.0.1:8000/"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["warning.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
